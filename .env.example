# Get a free API key at https://console.groq.com (no credit card required)
GROQ_API_KEY=gsk_your_api_key_here

# Primary model (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional fallback models tried in order if primary is rate-limited
# GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
# GROQ_FALLBACK_MODEL_2=gemma2-9b-it

# PostgreSQL connection string (Neon provides this in your dashboard)
# Format: postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=
